# Build output
build/
dist/
out/
target/
.gradle/
node_modules/

# Vendored CI actions tree: the shared reusable workflows check the github-workflows repo out
# into .github-workflows/ beside the sources. It is CI machinery, not this project's code, so it
# is never committed and is excluded from linting/formatting (antfu-eslint honours .gitignore).
.github-workflows/

# Env / secrets (never commit)
.env
.env.*
!.env.example
*.local

# Editor / OS
.idea/
.vscode/
.DS_Store
*.swp

# Logs
*.log

# Local planning and agent scratch artifacts
.specify/
specs/[0-9][0-9][0-9]-*/
plans/
planning/
scratchpad/
scratchpads/
.agent-council/
**/*scratchpad*.md
**/*.scratch.md
**/*agent-council*.md
.claude/commands/speckit*.md
.claude/skills/speckit*/
.agents/skills/speckit*/
templates/**/.specify/
templates/**/.claude/commands/speckit*.md
