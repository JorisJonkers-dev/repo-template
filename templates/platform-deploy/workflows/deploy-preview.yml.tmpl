# Deploy Preview for deploy-platform service repos.
#
# Any PR touching platform/ gets a full render + validation and a sticky
# "Deploy Preview" comment with the SC-11 readiness scorecard. The reusable
# deploy-validate.yml workflow owns the gate-summary emission and the comment.
name: Deploy Preview

on:
  pull_request:
    paths:
      - 'platform/**'

permissions: {}

jobs:
  deploy-preview:
    uses: JorisJonkers-dev/github-workflows/.github/workflows/deploy-validate.yml@f6c2969d7f1f4555da3b2cf46ce6a9b364c471b3 # v0.12.0
    with:
      deploy-dir: platform
      schema-version: '{{schema_version}}'
      image-lock-path: platform/images.lock.json
      context-ref: '{{context_ref}}'
      environments: production
      comment: true
    permissions:
      contents: read
      packages: read
      pull-requests: write
