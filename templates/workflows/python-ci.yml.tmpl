name: CI

on:
  pull_request:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

jobs:
  verify:
    uses: JorisJonkers-dev/github-workflows/.github/workflows/python-ci.yml@v0.6.0
    with:
      python-version: "3.13"
      working-directory: "."
      install-command: python -m pip install -r requirements-dev.txt
      lint-command: ruff check .
      test-command: python -m unittest discover

  pipeline-complete:
    name: Pipeline Complete
    if: always()
    needs: [verify]
    runs-on: ubuntu-latest
    steps:
      - uses: re-actors/alls-green@release/v1
        with:
          jobs: ${{ toJSON(needs) }}
