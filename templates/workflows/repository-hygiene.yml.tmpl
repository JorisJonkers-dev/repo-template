name: Repository Hygiene

on:
  pull_request:

permissions:
  contents: read
  pull-requests: read

jobs:
  repository-hygiene:
    uses: JorisJonkers-dev/github-workflows/.github/workflows/repository-hygiene-guard.yml@{{github_workflows_ref}}
    with:
      allowlist-regex: '{{hygiene_allowlist_regex}}'
    secrets: inherit
