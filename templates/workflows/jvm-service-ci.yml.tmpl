name: CI

on:
  pull_request:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

jobs:
  jvm:
    uses: JorisJonkers-dev/github-workflows/.github/workflows/jvm-ci.yml@v0.6.0
    with:
      java-version: "21"
      working-directory: "."
      lint-gradle-args: check
      test-gradle-args: build jacocoTestCoverageVerification
    secrets: inherit

  docker-image:
    uses: JorisJonkers-dev/github-workflows/.github/workflows/docker-image-ci.yml@v0.6.0
    with:
      image-name: "{{image_name}}"
      context: "."
      dockerfile: "Dockerfile"
    secrets: inherit

  migration-guard:
    uses: JorisJonkers-dev/github-workflows/.github/workflows/migration-guard.yml@v0.6.0

  pipeline-complete:
    name: Pipeline Complete
    if: always()
    needs: [jvm, docker-image, migration-guard]
    runs-on: ubuntu-latest
    steps:
      - uses: re-actors/alls-green@release/v1
        with:
          jobs: ${{ toJSON(needs) }}
